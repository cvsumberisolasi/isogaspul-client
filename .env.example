# ============================================
# ISOGASPUL RACING — Environment Template
# ============================================
# Copy file ini ke .env dan isi dengan kredensial asli.
# File .env TIDAK BOLEH di-commit ke Git.

# --- InsForge Backend ---
VITE_INSFORGE_API_URL=https://YOUR_PROJECT.ap-southeast.insforge.app
VITE_INSFORGE_ANON_KEY=your-anon-jwt-token-here
VITE_INSFORGE_ADMIN_KEY=your-admin-anon-key-here

# --- Database (SERVER-SIDE ONLY) ---
DATABASE_URL=postgresql://postgres:PASSWORD@YOUR_PROJECT.ap-southeast.database.insforge.app:5432/insforge

# --- S3 / InsForge Storage (SERVER-SIDE ONLY) ---
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_ENDPOINT=https://YOUR_PROJECT.ap-southeast.insforge.app/storage/v1/s3
S3_REGION=us-east-2
S3_BUCKET=your-bucket-name

# --- Admin Login ---
VITE_ADMIN_EMAIL=admin@example.com
VITE_ADMIN_PASSWORD=your-admin-password

# --- WhatsApp ---
VITE_WA_NUMBER=628xxxxxxxxxx
